# Collapse alias variants (e.g. spectre is a render-only variant of demon)
# down to the canonical type used by per-stat lookups.
function thing_base_type(type)
    if type == THING_SPECTRE
        return THING_DEMON
    end
    return type
end

# Generic field accessor — returns row[field], or default if either the
# row or the field is absent.
function _minfo_field(type, field, default)
    type = thing_base_type(type)
    local row = MONSTER_INFO[format("{}", type)]
    if row == none
        return default
    end
    local v = row[field]
    if v == none
        return default
    end
    return v
end

function thing_default_health(type)
    return _minfo_field(type, "health", 0)
end
function thing_default_speed(type)
    return _minfo_field(type, "speed", 0)
end
function thing_default_radius(type)
    return _minfo_field(type, "radius", 20)
end
function thing_default_height(type)
    return _minfo_field(type, "height", 56)
end
function thing_default_damage(type)
    return _minfo_field(type, "damage", 0)
end
function thing_default_pain(type)
    return _minfo_field(type, "pain_chance", 0)
end
function thing_attack_rate(type)
    return _minfo_field(type, "attack_rate", 35)
end

function thing_floats(type)
    return _minfo_field(type, "floats", false)
end

function thing_is_melee(type)
    return _minfo_field(type, "melee", false)
end

function thing_attack_dist(type)
    if thing_is_melee(type)
        return 80
    end
    return 512
end

# ── Pickup classification ───────────────────────────────────────────
#
# A small set of type ids that should get TF_PICKUP. Centralised so
# `thing_default_flags` is one table lookup instead of a dozen branch
# tests against id ranges.
PICKUP_IDS = {}
function _pickup(type)
    PICKUP_IDS[format("{}", type)] = true
end

_pickup(THING_STIMPACK)     _pickup(THING_MEDIKIT)
_pickup(THING_ARMOR_G)      _pickup(THING_ARMOR_B)
_pickup(THING_SHOTGUN)      _pickup(THING_CHAINGUN)
_pickup(THING_LAUNCHER)     _pickup(THING_PLASMA)
_pickup(THING_BFG)          _pickup(THING_CHAINSAW)
_pickup(THING_HEALTH_BONUS) _pickup(THING_ARMOR_BONUS)
_pickup(THING_SOULSPHERE)   _pickup(THING_MEGASPHERE)
_pickup(THING_INVULN)       _pickup(THING_BERSERK)
_pickup(THING_INVIS)        _pickup(THING_RADSUIT)
_pickup(THING_ALLMAP)       _pickup(THING_VISOR)
_pickup(THING_BLUE_KEY)     _pickup(THING_YELLOW_KEY)
_pickup(THING_RED_KEY)
_pickup(THING_AMMO_CLIP)    _pickup(THING_AMMO_SHELL)
_pickup(THING_AMMO_ROCKET)  _pickup(THING_AMMO_CELL)
_pickup(THING_AMMO_BOX_CLIP)   _pickup(THING_AMMO_BOX_SHELL)
_pickup(THING_AMMO_BOX_ROCKET) _pickup(THING_AMMO_BOX_CELL)
_pickup(THING_BACKPACK)

function thing_default_flags(type)
    if type == THING_TELEDEST
        return 0
    end
    if MONSTER_INFO[format("{}", thing_base_type(type))] != none
        # Barrel is shootable but not a monster.
        if type == THING_BARREL
            return TF_SOLID + TF_SHOOTABLE
        end
        return TF_SOLID + TF_SHOOTABLE + TF_MONSTER
    end
    if PICKUP_IDS[format("{}", type)] == true
        return TF_PICKUP
    end
    return TF_SOLID
end

# ── Sprite prefixes ─────────────────────────────────────────────────
#
# 4-char WAD lump prefix per thing type. thing_sprite_name appends an
# animation frame letter and "0".
SPRITE_PREFIX = {}
function _spfx(type, name)
    SPRITE_PREFIX[format("{}", type)] = name
end

