# things_defs.is — Actors, monsters, items, projectiles
#
# Per-type data lives in declarative tables keyed by "type number as
# string" (isilly tables use string keys). Accessor functions are thin
# wrappers around those tables, so adding a new monster or item only
# requires editing data, not control flow.
#
# Re-enable safe now that the underlying isilly_table_set bug (key
# pointers were stored without strdup, so format("{}", x) keys went
# dangling) is fixed. The gameplay invariant test in tests/run_tests.sh
# section 6.5 catches any regression in sprite name resolution.
#
# things_active uses string keys: things_active[format("{}", i)]

THING_PLAYER1    = 1
THING_PLAYER2    = 2
THING_PLAYER3    = 3
THING_PLAYER4    = 4
THING_ZOMBIEMAN  = 3004
THING_SHOTGUNNER = 9
THING_IMP        = 3001
THING_DEMON      = 3002
THING_SPECTRE    = 58    # Same stats as DEMON but rendered with FUZZ
THING_BARON      = 3003
THING_CACO       = 3005
THING_SOUL       = 3006
THING_SPIDER     = 7
THING_CYBER      = 16

THING_STIMPACK    = 2011
THING_MEDIKIT     = 2012
THING_ARMOR_G     = 2018
THING_ARMOR_B     = 2019
THING_SHOTGUN     = 2001
THING_CHAINGUN    = 2002
THING_LAUNCHER    = 2003
THING_PLASMA      = 2004
THING_BFG         = 2006
THING_CHAINSAW    = 2005
THING_HEALTH_BONUS = 2014
THING_ARMOR_BONUS  = 2015
THING_SOULSPHERE  = 2013
THING_MEGASPHERE  = 83
THING_INVULN      = 2022
THING_BERSERK     = 2023
THING_INVIS       = 2024
THING_RADSUIT     = 2025
THING_ALLMAP      = 2026
THING_VISOR       = 2045
THING_BLUE_KEY    = 5
THING_YELLOW_KEY  = 6
THING_RED_KEY     = 13
THING_TELEDEST    = 14
THING_BARREL      = 2035
THING_AMMO_CLIP   = 2007
THING_AMMO_SHELL  = 2008
THING_AMMO_ROCKET = 2010
THING_AMMO_CELL   = 2047
THING_AMMO_BOX_CLIP   = 2048
THING_AMMO_BOX_SHELL  = 2049
THING_AMMO_BOX_ROCKET = 2046
THING_AMMO_BOX_CELL   = 17     # Energy cell pack
THING_BACKPACK        = 8      # Doubles ammo caps + gives one of each

# Thing flags (from the WAD's actor flag word)
TF_SOLID     = 1
TF_SHOOTABLE = 2
TF_PICKUP    = 4
TF_MISSILE   = 8
TF_MONSTER   = 16

# Map-thing skill flags (from the WAD THINGS lump's flag word — these
# live in a different field than TF_* and have different bit values)
MTF_EASY     = 1   # Appears in skill 1 + 2
MTF_NORMAL   = 2   # Appears in skill 3
MTF_HARD     = 4   # Appears in skill 4 + 5
MTF_AMBUSH   = 8   # Deaf monster
MTF_MULTI    = 16  # Multiplayer-only

AI_IDLE    = 0
AI_SEE     = 1
AI_CHASE   = 2
AI_MELEE   = 3
AI_MISSILE = 4
AI_PAIN    = 5
AI_DEATH   = 6
AI_DEAD    = 7

things_active = {}
things_count  = 0

# ── Per-monster data ────────────────────────────────────────────────
#
# MONSTER_INFO[type_str] = {
#   health, speed, radius, height, damage, pain_chance, attack_rate,
#   floats, melee, sprite,
#   see_snd, atk_snd, die_snd, pain_snd,
# }
#
# Sourced from vanilla mobjinfo + S_*_SEE/S_*_DIE state chains. Empty
# string in a sound field means "no sound for this monster" — vanilla
# Lost Soul / Spider / Cyberdemon use different sound logic that's
# easier to handle as a noop than to special-case.
MONSTER_INFO = {}

function _mdef(type, info)
    MONSTER_INFO[format("{}", type)] = info
end

_mdef(THING_ZOMBIEMAN, {
