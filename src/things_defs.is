function thing_sprite_prefix(type)
    local p = SPRITE_PREFIX[format("{}", type)]
    if p == none
        return ""
    end
    return p
end

# Pose-specific decorations and corpses use a non-A frame baked into
# the lump name (e.g. PLAYN0 for a dead marine). Returns the full
# lump name, or "" for animated/A0 things.
DECO_LUMP = {}
function _deco(type, lump)
    DECO_LUMP[format("{}", type)] = lump
end

_deco(10, "PLAYW0")  # bloody mess (variant 1)
_deco(12, "PLAYN0")  # dead player
_deco(15, "PLAYN0")  # dead other
_deco(18, "POSSL0")  # dead former human
_deco(19, "SPOSL0")  # dead former sergeant
_deco(20, "TROOM0")  # dead imp
_deco(21, "SARGN0")  # dead demon
_deco(22, "HEADL0")  # dead cacodemon
_deco(24, "POL5A0")  # pool of blood

function thing_decoration_lump(type)
    local d = DECO_LUMP[format("{}", type)]
    if d == none
        return ""
    end
    return d
end

# Animated sprite frame letter based on AI state + tics
function thing_sprite_frame(th)
    local frames = "ABCD"
    if th.ai == AI_IDLE or th.ai == AI_SEE
        # Walk cycle: A B C D
        local idx = (th.tics / 4) % 4
        return charAt(frames, idx)
    end
    if th.ai == AI_CHASE
        local idx = (th.tics / 4) % 4
        return charAt(frames, idx)
    end
    if th.ai == AI_MELEE or th.ai == AI_MISSILE
        return "E"
    end
    if th.ai == AI_PAIN
        return "G"
    end
    if th.ai == AI_DEATH
        local idx = th.tics / 3
        if idx > 4
            idx = 4
        end
        local death_frames = "LMNOP"
        return charAt(death_frames, idx)
    end
    if th.ai == AI_DEAD
        return "P"
    end
    return "A"
end

# Full sprite lump name for a thing (prefix + frame + "0")
function thing_sprite_name(th)
    # Projectiles set their own sprite prefix at spawn time so we don't
    # have to plumb every kind through thing_sprite_prefix.
    if (th.flags & TF_MISSILE) != 0 and th.sprite_pfx != none
        return th.sprite_pfx + "A0"
    end
    # Pose-specific decorations (corpses, blood pools) use a non-A frame
    # baked into the lump name. Check before the prefix path so we don't
    # accidentally append "A0" and miss the cache.
    local deco = thing_decoration_lump(th.type)
    if deco != ""
        return deco
    end
    local pfx = thing_sprite_prefix(th.type)
    if pfx == ""
        return ""
    end
    # Items don't animate — always A0
    if (th.flags & TF_PICKUP) != 0
        return pfx + "A0"
    end
    # Monsters use animated frames
    if (th.flags & TF_MONSTER) != 0
        local frame = thing_sprite_frame(th)
        return pfx + frame + "0"
    end
    # Default
    return pfx + "A0"
end

# ── Sound dispatch ──────────────────────────────────────────────────
#
# Each sound family pulls from the matching field on MONSTER_INFO. An
# empty string means "no sound for this monster" (Lost Soul / Spider /
# Cyberdemon use different sound paths in vanilla).
function _play_monster_sound(th, field)
    local snd = _minfo_field(th.type, field, "")
    if snd != ""
        audio_play_sfx_pos(snd, th.x, th.y)
    end
end

function thing_play_see_sound(th)
    _play_monster_sound(th, "see_snd")
end
function thing_play_attack_sound(th)
    _play_monster_sound(th, "atk_snd")
end
function thing_play_death_sound(th)
    _play_monster_sound(th, "die_snd")
end
function thing_play_pain_sound(th)
    _play_monster_sound(th, "pain_snd")
end

# Barrel explosion — damages nearby things and player
function thing_barrel_explode(barrel)
    local bx = barrel.x
    local by = barrel.y
    local blast_radius = 128
    local blast_damage = 50

    audio_play_sfx_pos(SFX_BAREXP, bx, by)

    # Damage player if nearby
    local pdx = player_x - bx
    local pdy = player_y - by
    local pdist = sqrt(pdx * pdx + pdy * pdy)
    if pdist < blast_radius
        local dmg = blast_damage * (1.0 - pdist / blast_radius)
        player_take_damage(floor(dmg))
    end

    # Damage nearby things
    for i in range(things_count):
        local th = things_active[format("{}", i)]
        if th != none
            if th.health > 0 and th.x != bx and th.y != by
                local tdx = th.x - bx
                local tdy = th.y - by
                local tdist = sqrt(tdx * tdx + tdy * tdy)
                if tdist < blast_radius
                    local dmg = blast_damage * (1.0 - tdist / blast_radius)
                    thing_damage(th, floor(dmg))
                end
            end
        end
    end
end

function thing_damage(th, amount)
    if th.health <= 0
        return
    end
    th.health = th.health - amount

    if th.health <= 0
        th.health = 0
        th.ai = AI_DEATH
        th.tics = 0
        thing_play_death_sound(th)
        if (th.flags & TF_MONSTER) != 0
            g_kill_count = g_kill_count + 1
            # Drive the "evil grin" face for ~1 second after a kill —
            # the HUD already checks player_evil_tic, this is the
            # only place that ever sets it.
            player_evil_tic = 35
            # Nightmare: queue this monster for respawn ~12 seconds later
            if game_skill() == SKILL_NM
                respawn_queue_add(th.type, th.x, th.y, th.angle * 180 / PI)
            end
        end
        if th.type == THING_BARREL
            thing_barrel_explode(th)
        end
    else
        if rand() * 256 < th.pain_chance
            th.ai = AI_PAIN
            th.tics = 0
            thing_play_pain_sound(th)
        elif th.ai == AI_IDLE
            th.ai = AI_CHASE
            th.tics = 0
        end
    end
end
